# ======================================
# 야코리아 채팅 시스템 V2 — 환경변수 예시
# ======================================
# 이 파일을 복사해서 .env 파일을 만들고, 값을 채워 넣으세요.
# cp .env.example .env
#
# Railway 배포 시: 아래 항목들을 Railway 대시보드 Variables 탭에서 입력하세요.
# PORT는 Railway가 자동으로 주입하므로 입력하지 않아도 됩니다.
# ======================================

# --- 서버 설정 ---
# PORT는 Railway가 자동 설정 (직접 입력 불필요)
NODE_ENV=production

# --- Supabase 설정 ---
# Supabase 대시보드 → Project Settings → API 에서 확인
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- JWT 인증 설정 ---
# 프로덕션에서는 반드시 긴 랜덤 문자열로 변경하세요.
# 생성: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this

# --- 관리자 계정 ---
MANAGER_EMAIL=manager@yakorea.com
MANAGER_PASSWORD=your-secure-password

# --- CORS 허용 도메인 ---
# 쉼표로 구분. Vercel 배포 후 해당 URL을 반드시 추가하세요.
# 예: https://yakorea-admin.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=https://your-admin.vercel.app
