# cp .env.local.example .env.local
#
# Vercel 배포 시: Vercel 대시보드 → Settings → Environment Variables 에서 입력
# ============================================================

# 채팅 서버 주소 (Railway 배포 후 발급되는 URL로 교체)
# 예: https://yakorea-chat-server.railway.app
NEXT_PUBLIC_API_URL=https://your-server.railway.app
